generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core Enums
enum UserSex {
  MALE
  FEMALE
  OTHER
}

enum AssessmentType {
  DIAGNOSTIC
  FORMATIVE
  SUMMATIVE
  PERFORMANCE_BASED
  ADAPTIVE
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LearningDomain {
  COGNITIVE
  AFFECTIVE
  PSYCHOMOTOR
  METACOGNITIVE
}

enum LearningStyle {
  VISUAL
  AUDITORY
  KINESTHETIC
  READING_WRITING
  MULTIMODAL
}

enum LearningPathType {
  ACADEMIC_ENRICHMENT
  SKILL_DEVELOPMENT
  CAREER_PREPARATION
  PERSONAL_GROWTH
}

enum LearningProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  MASTERED
  NEEDS_IMPROVEMENT
}

enum LearningGoalType {
  ACADEMIC_IMPROVEMENT
  SKILL_DEVELOPMENT
  CAREER_PREPARATION
  PERSONAL_GROWTH
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum RiskCategory {
  ACADEMIC
  ATTENDANCE
  BEHAVIORAL
  SOCIAL_EMOTIONAL
  FINANCIAL
}

enum InterventionType {
  ACADEMIC_SUPPORT
  EMOTIONAL_SUPPORT
  SKILL_DEVELOPMENT
  CAREER_GUIDANCE
  MENTAL_HEALTH
}

enum InterventionPlanStatus {
  INITIATED
  IN_PROGRESS
  SUCCESSFUL
  NEEDS_REVIEW
  DISCONTINUED
}

enum PredictionConfidence {
  LOW
  MEDIUM
  HIGH
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum CognitiveLoadLevel {
  LOW
  MODERATE
  HIGH
  OVERWHELMING
}

enum LearningPathComplexity {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum RecommendationOutcome {
  COMPLETED
  PARTIAL
  ABANDONED
}

enum InclusionMetricType {
  ACADEMIC_SUPPORT
  RESOURCE_ACCESS
  MENTORSHIP
  COMMUNITY_ENGAGEMENT
}

enum DiversityCategory {
  RACE
  GENDER
  SOCIOECONOMIC
  DISABILITY
  FIRST_GENERATION
}

enum InterventionOutcome {
  SUCCESSFUL
  PARTIALLY_SUCCESSFUL
  UNSUCCESSFUL
}

enum SupportModelType {
  PREDICTIVE
  PRESCRIPTIVE
  DIAGNOSTIC
  ADAPTIVE
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PAUSED
}

enum CurriculumType {
  STANDARD
  ADVANCED
  SPECIALIZED
  INTERDISCIPLINARY
}

enum CurriculumStatus {
  DRAFT
  APPROVED
  ACTIVE
  ARCHIVED
}

enum CourseDeliveryMode {
  IN_PERSON
  ONLINE
  HYBRID
  SELF_PACED
}

enum ApprenticeshipCategory {
  TECHNICAL
  PROFESSIONAL
  RESEARCH
  CREATIVE
}

enum ApprenticeshipStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  TERMINATED
}

enum SkillProficiencyLevel {
  NOVICE
  BEGINNER
  COMPETENT
  PROFICIENT
  EXPERT
}

enum ScholarshipType {
  MERIT_BASED
  NEED_BASED
  DIVERSITY
  RESEARCH
  INTERNATIONAL
}

enum ScholarshipStatus {
  PENDING
  AWARDED
  ACTIVE
  COMPLETED
  REVOKED
}

enum FundingSource {
  INSTITUTIONAL
  GOVERNMENT
  PRIVATE
  CORPORATE
  PHILANTHROPIC
}

enum PartnershipType {
  ACADEMIC
  INDUSTRY
  RESEARCH
  COMMUNITY
  INTERNATIONAL
}

enum PartnershipStatus {
  PROSPECTIVE
  NEGOTIATING
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum CollaborationType {
  RESEARCH
  EDUCATIONAL
  TECHNOLOGICAL
  CULTURAL
  STRATEGIC
}

enum CollaborationStatus {
  PROSPECTIVE
  PLANNING
  IN_PROGRESS
  COMPLETED
  DISCONTINUED
}

enum ComplianceLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ResearchDomain {
  STEM
  SOCIAL_SCIENCES
  HUMANITIES
  INTERDISCIPLINARY
  APPLIED_RESEARCH
}

enum ResearchStatus {
  PROPOSAL
  APPROVED
  IN_PROGRESS
  COMPLETED
  PUBLISHED
}

enum LearningOutcomeCategory {
  KNOWLEDGE
  SKILLS
  COMPETENCIES
  ATTITUDES
  PROFESSIONAL_DEVELOPMENT
}

enum MentorRating {
  EXCELLENT
  GOOD
  SATISFACTORY
  NEEDS_IMPROVEMENT
}

// New Enums
enum DivisionType {
  ACADEMIC
  ADMINISTRATIVE
  RESEARCH
  SUPPORT
  EXTENSION
}

enum PartnerType {
  ACADEMIC_INSTITUTION
  CORPORATE
  NON_PROFIT
  GOVERNMENT
  INTERNATIONAL
}

enum EligibilityCriteriaType {
  ACADEMIC_PERFORMANCE
  FINANCIAL_NEED
  DEMOGRAPHIC
  EXTRACURRICULAR
  RESEARCH_POTENTIAL
}

// User and Authentication Models
model User {
  id                          String                   @id @default(cuid())
  username                    String                   @unique
  email                       String                   @unique
  password                    String
  role                        String
  
  // Back-references
  researchers                 Researcher[]
  divisions                   Division[]
  userConsentProfile          UserConsentProfile?
  notifications               Notification[]
}

// Student Model
model Student {
  id                          String                   @id @default(cuid())
  username                    String                   @unique
  name                        String
  surname                     String
  email                       String?                  @unique
  phone                       String?                  @unique
  address                     String
  img                         String?
  bloodType                   String
  sex                         UserSex
  createdAt                   DateTime                 @default(now())
  parentId                    String
  parent                      Parent                   @relation(fields: [parentId], references: [id])
  classId                     Int
  class                       Class                    @relation(fields: [classId], references: [id])
  gradeId                     Int
  grade                       Grade                    @relation(fields: [gradeId], references: [id])
  
  // Relationships
  attendances                 Attendance[]
  results                     Result[]
  birthday                    DateTime
  academicInterventionPlans   AcademicInterventionPlan[]
  scholarshipEvaluations      ScholarshipEvaluation?
  learningPathways            LearningPathway[]
  learningInterventions       LearningIntervention[]
  learningInterventionLogs    LearningInterventionLog[]
  studentInteractions         StudentInteraction[]
  learningRecommendations     LearningRecommendation[]
  performancePredictions      PerformancePrediction?
  personalizedLearningProfile PersonalizedLearningProfile?
  learningGoalAnalyses        LearningGoalAnalysis[]
  performanceMetrics          PerformanceMetric[]
  studentRiskAssessments      StudentRiskAssessment[]
  supportTickets              SupportTicket[]
  earlyWarningTriggers        EarlyWarningTrigger[]
  recommendationHistory       RecommendationTracking[]
  equityProfile               EquityProfile?
  interventionPlans           InterventionPlan[]
  riskPredictions             RiskPrediction[]
  interventionStrategies      InterventionStrategy[]
  studentGrowthProfile        StudentGrowthProfile?
  studentGrowthRecords        StudentGrowthRecord[]
  researchProjects            ResearchProject[]
  assessmentResponses         StudentAssessmentResponse[]
  assessmentResults           StudentAssessmentResult[]
  learningPaths               LearningPath[]
  studentResourceProgress     StudentResourceProgress[]
  courseEnrollments           StudentCourseEnrollment[]
  studentAssessments          StudentAssessment[]
  apprenticeships             Apprenticeship[]
  scholarships                Scholarship[]
  studentLearningProfile      StudentLearningProfile?
  learningProfile             LearningProfile?
  mlSupportModel              MLSupportModel?
}

// Assessment Models
model Assessment {
  id                          String                   @id @default(cuid())
  title                       String
  description                 String?
  type                        AssessmentType
  subject                     String
  learningObjectives          String[]
  startTime                   DateTime?
  endTime                     DateTime?
  duration                    Int?
  adaptiveMode                Boolean                  @default(false)
  personalizationLevel        Float                    @default(0.5)
  scoringMethod               String
  passingThreshold            Float
  createdBy                   String
  tags                        String[]
  assessmentItems             AssessmentItem[]
  studentResults              StudentAssessmentResult[]
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
}

model AssessmentItem {
  id                          String                   @id @default(cuid())
  assessmentId                String
  assessment                  Assessment               @relation(fields: [assessmentId], references: [id])
  questionText                String
  type                        AssessmentType
  difficultyLevel             DifficultyLevel
  learningDomain              LearningDomain
  subject                     String
  topic                       String
  learningObjective           String
  maxScore                    Float
  scoringRubric               Json
  aiGeneratedDistractors      String[]
  adaptiveParameters          Json?
  multimedia                  Json?
  studentResponses            StudentAssessmentResponse[]
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
}

// Parent Model
model Parent {
  id        String    @id @default(cuid())
  username  String    @unique
  name      String
  surname   String
  email     String?   @unique
  phone     String    @unique
  address   String
  createdAt DateTime  @default(now())
  students  Student[]
}

// Class Model
model Class {
  id       Int    @id @default(autoincrement())
  name     String @unique
  capacity Int

  supervisorId  String?
  supervisor    Teacher?       @relation(fields: [supervisorId], references: [id])
  lessons       Lesson[]
  students      Student[]
  gradeId       Int
  grade         Grade          @relation(fields: [gradeId], references: [id])
  events        Event[]
  announcements Announcement[]
}

// Grade Model
model Grade {
  id    Int @id @default(autoincrement())
  level Int @unique

  students Student[]
  classes Class[]
}

// Teacher Model
model Teacher {
  id        String    @id @default(cuid())
  username  String    @unique
  name      String
  surname   String
  email     String?   @unique
  phone     String?   @unique
  address   String
  img       String?
  bloodType String
  sex       UserSex
  createdAt DateTime  @default(now())
  subjects  Subject[]
  lessons   Lesson[]
  classes   Class[]
  birthday  DateTime
  managedInterventionPlans  InterventionPlan[]
  managedInterventionStrategies  InterventionStrategy[]
}

// Subject Model
model Subject {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  teachers Teacher[]
  lessons  Lesson[]
}

// Lesson Model
model Lesson {
  id        Int      @id @default(autoincrement())
  name      String
  day       Day
  startTime DateTime
  endTime   DateTime

  subjectId   Int
  subject     Subject      @relation(fields: [subjectId], references: [id])
  classId     Int
  class       Class        @relation(fields: [classId], references: [id])
  teacherId   String
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  exams       Exam[]
  assignments Assignment[]
  attendances Attendance[]
}

// Exam Model
model Exam {
  id        Int      @id @default(autoincrement())
  title     String
  startTime DateTime
  endTime   DateTime

  lessonId Int
  lesson   Lesson   @relation(fields: [lessonId], references: [id])
  results  Result[]
}

// Assignment Model
model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  startDate DateTime
  dueDate   DateTime

  lessonId Int
  lesson   Lesson   @relation(fields: [lessonId], references: [id])
  results  Result[]
}

// Result Model
model Result {
  id    Int @id @default(autoincrement())
  score Int

  examId       Int?
  exam         Exam?       @relation(fields: [examId], references: [id])
  assignmentId Int?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student     @relation(fields: [studentId], references: [id])
}

// Attendance Model
model Attendance {
  id      Int      @id @default(autoincrement())
  date    DateTime
  present Boolean

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  lessonId  Int
  lesson    Lesson  @relation(fields: [lessonId], references: [id])
}

// Event Model
model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])
}

// Announcement Model
model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  date        DateTime

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])
}

// Academic Intervention Plan Model
model AcademicInterventionPlan {
  id                String   @id @default(cuid())
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id])
  interventionType  String
  description       String
  startDate         DateTime @default(now())
  endDate           DateTime?
  status            String   @default("ACTIVE")
  recommendedResources Json?
}

// Scholarship Evaluation Model
model ScholarshipEvaluation {
  id                String   @id @default(cuid())
  studentId         String   @unique
  student           Student  @relation(fields: [studentId], references: [id])
  evaluationDate    DateTime @default(now())
  averageScore      Float
  scholarshipLevel  String
  fundingPercentage Int
  additionalSupport Json?
}

// Learning Pathway Model
model LearningPathway {
  id                String   @id @default(cuid())
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id])
  recommendedCourses Json
  intensityLevel    String
  lastUpdated       DateTime @default(now())
}

// Learning Intervention Model
model LearningIntervention {
  id                  String    @id @default(cuid())
  studentId           String    @unique
  student             Student   @relation(fields: [studentId], references: [id])
  subject             String
  interventionType    String
  startDate           DateTime
  endDate             DateTime?
  progress            Float     @default(0)
  notes               String?
}

// Student Assessment Response Model
model StudentAssessmentResponse {
  id                          String           @id @default(cuid())
  studentId                   String
  student                     Student          @relation(fields: [studentId], references: [id])
  
  assessmentItemId            String
  assessmentItem              AssessmentItem  @relation(fields: [assessmentItemId], references: [id])
  
  // Response Details
  responseText                String?
  selectedOption              String?
  score                       Float?
  
  // Performance Metadata
  timeTaken                   Int?
  confidenceLevel             Float?
  
  createdAt                   DateTime         @default(now())
}

// Student Assessment Result Model
model StudentAssessmentResult {
  id                          String           @id @default(cuid())
  studentId                   String
  student                     Student          @relation(fields: [studentId], references: [id])
  
  assessmentId                String
  assessment                  Assessment       @relation(fields: [assessmentId], references: [id])
  
  // Performance Metrics
  totalScore                  Float
  percentageScore             Float
  performanceLevel            String
  
  // Adaptive and Personalized Insights
  personalizedFeedback        String?
  recommendedLearningPath     Json?
  
  // Performance Analysis
  strengthAreas               String[]
  improvementAreas            String[]
  
  createdAt                   DateTime         @default(now())
}

// Student Learning Profile Model
model StudentLearningProfile {
  id                String           @id @default(cuid())
  studentId         String           @unique
  student           Student          @relation(fields: [studentId], references: [id])
  primaryLearningStyle LearningStyle
  cognitiveLoadLevel CognitiveLoadLevel
  learningStyleStrengths String[]
  learningStyleWeaknesses String[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

// Student Interaction Model
model StudentInteraction {
  id                String           @id @default(cuid())
  studentId         String
  student           Student          @relation(fields: [studentId], references: [id])
  interactionType   String
  resourceType      String
  duration          Int
  engagement        Float
  timestamp         DateTime         @default(now())
}

// Learning Recommendation Model
model LearningRecommendation {
  id                String           @id @default(cuid())
  studentId         String
  student           Student          @relation(fields: [studentId], references: [id])
  recommendationType String
  description       String
  resources         Json
  startDate         DateTime         @default(now())
  endDate           DateTime?
  status            String           @default("ACTIVE")
}

// Performance Prediction Model
model PerformancePrediction {
  id                String           @id @default(cuid())
  studentId         String           @unique
  student           Student          @relation(fields: [studentId], references: [id])
  predictedScore    Float
  confidenceInterval Json
  predictionDate    DateTime         @default(now())
  performanceGrowthPlan Json
}

// Personalized Learning Profile Model
model PersonalizedLearningProfile {
  id                      String               @id @default(cuid())
  studentId               String               @unique
  student                 Student              @relation(fields: [studentId], references: [id])
  primaryLearningGoal     LearningGoalType
  learningPathComplexity  LearningPathComplexity
  recommendedPrimaryPath  String
  strategicObjectives     String[]
  supportMechanisms       String[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
}

// Learning Goal Analysis Model
model LearningGoalAnalysis {
  id                      String               @id @default(cuid())
  studentId               String
  student                 Student              @relation(fields: [studentId], references: [id])
  goalType                LearningGoalType
  goalInterpretation      String
  keyLearningOpportunities Json
  potentialChallenges     Json
  successProbability      Float
  analysisDate            DateTime             @default(now())
}

// Performance Metric Model
model PerformanceMetric {
  id                      String               @id @default(cuid())
  studentId               String
  student                 Student              @relation(fields: [studentId], references: [id])
  academicPerformance     Float
  skillDevelopment        Float
  careerPreparation       Float
  personalGrowth          Float
  overallProgressScore    Float
  metricDate              DateTime             @default(now())
}

// Student Risk Assessment Model
model StudentRiskAssessment {
  id                          String               @id @default(cuid())
  studentId                   String
  student                     Student              @relation(fields: [studentId], references: [id])
  academicRiskLevel           RiskLevel
  emotionalRiskLevel          RiskLevel
  skillDevelopmentRiskLevel   RiskLevel
  careerPreparationRiskLevel  RiskLevel
  overallRiskLevel            RiskLevel
  detailedAnalysis            String
  assessmentDate              DateTime             @default(now())
}

// Learning Intervention Log Model
model LearningInterventionLog {
  id                String               @id @default(cuid())
  studentId         String
  student           Student              @relation(fields: [studentId], references: [id])
  interventionType  InterventionType
  riskLevel         RiskLevel
  interventionPlan  Json
  progressTracking  Json?
  status            String               @default("ACTIVE")
  startDate         DateTime             @default(now())
  expectedCompletionDate  DateTime?
  actualCompletionDate    DateTime?
}

// Support Ticket Model
model SupportTicket {
  id                      String               @id @default(cuid())
  interventionPlanId      String?
  studentId               String?
  student                 Student?             @relation(fields: [studentId], references: [id])
  priority                String
  status                  String
  description             String
  assignedTo              String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
}

// Early Warning Trigger Model
model EarlyWarningTrigger {
  id                      String               @id @default(cuid())
  studentId               String
  student                 Student              @relation(fields: [studentId], references: [id])
  riskType                String
  currentRiskLevel        RiskLevel
  triggerDescription      String
  detectedAt              DateTime             @default(now())
}

// Learning Path Model
model LearningPath {
  id                          String              @id @default(cuid())
  studentId                   String
  student                     Student             @relation(fields: [studentId], references: [id])
  
  // Path Configuration
  type                        LearningPathType
  title                       String
  description                 String?
  
  // Learning Objectives
  primaryObjective            String
  secondaryObjectives         String[]
  
  // Path Composition
  learningResources           LearningResource[]
  
  // Personalization Metrics
  learningStyle               LearningStyle
  personalizedRecommendationFactor Float
  
  // Temporal Tracking
  startDate                   DateTime
  expectedCompletionDate      DateTime
  actualCompletionDate        DateTime?
  
  // Progress Tracking
  progressStatus              LearningProgressStatus
  completionPercentage        Float
  
  // AI and ML Insights
  aiGeneratedInsights         Json?
  
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Learning Resource Model
model LearningResource {
  id                          String              @id @default(cuid())
  learningPathId              String
  learningPath                LearningPath        @relation(fields: [learningPathId], references: [id])
  
  // Resource Details
  title                       String
  type                        String
  url                         String
  
  // Learning Metadata
  subject                     String
  difficulty                  String
  learningObjectives          String[]
  
  // Personalization Parameters
  recommendationScore         Float?
  learningStyles              String[]
  
  // Engagement Metrics
  averageCompletionTime       Int?
  userRating                  Float?
  
  // Student Progress Tracking
  studentProgress             StudentResourceProgress[]
  
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Student Resource Progress Model
model StudentResourceProgress {
  id                          String              @id @default(cuid())
  studentId                   String
  student                     Student             @relation(fields: [studentId], references: [id])
  
  resourceId                  String
  resource                    LearningResource    @relation(fields: [resourceId], references: [id])
  
  // Progress Details
  startTime                   DateTime
  completionTime              DateTime?
  
  // Performance Metrics
  timeSpent                   Int?
  completionStatus            String
  performanceScore            Float?
  
  // Engagement Tracking
  interactionLevel            Float?
  
  createdAt                   DateTime            @default(now())
}

// Learning Profile Model
model LearningProfile {
  id            String        @id @default(cuid())
  studentId     String        @unique
  student       Student       @relation(fields: [studentId], references: [id])
  primaryStyle  LearningStyle
  secondaryStyle LearningStyle?
  preferredModalities String[]
  learningPace  String
  strengthAreas String[]
  challengeAreas String[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// Recommendation Tracking Model
model RecommendationTracking {
  id              String              @id @default(cuid())
  studentId       String
  student         Student             @relation(fields: [studentId], references: [id])
  recommendationId String
  outcome         RecommendationOutcome
  confidence      Float
  relevanceScore  Float
  recommendationType String
  timestamp       DateTime            @default(now())
  additionalMetadata Json?
}

// Equity Profile Model
model EquityProfile {
  id                   String             @id @default(cuid())
  studentId            String             @unique
  student              Student            @relation(fields: [studentId], references: [id])
  
  // Demographic Information
  race                 String?
  gender               String?
  socioeconomicStatus  String?
  isFirstGeneration    Boolean            @default(false)
  hasDisability        Boolean            @default(false)

  // Additional Context
  primaryLanguage      String?
  immigrationStatus    String?
  
  // Tracking Metrics
  inclusionMetrics     InclusionMetric[]
  
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

// Inclusion Metric Model
model InclusionMetric {
  id                   String             @id @default(cuid())
  equityProfileId      String
  equityProfile        EquityProfile      @relation(fields: [equityProfileId], references: [id])
  
  metricType           InclusionMetricType
  score                Float
  
  // Contextual Information
  academicYear         Int
  semester             String?
  
  // Trend and Comparative Data
  nationalBenchmark    Float?
  institutionalAverage Float?
  
  createdAt            DateTime           @default(now())
}

// Equity Intervention Model
model EquityIntervention {
  id                   String             @id @default(cuid())
  title                String
  description          String
  category             DiversityCategory
  
  // Intervention Tracking
  implementationDate   DateTime
  targetGroups         String[]
  expectedOutcomes     String[]
  
  // Outcome Tracking
  actualOutcomes       String[]
  successRate          Float?
  
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

// Intervention Plan Model
model InterventionPlan {
  id                String                @id @default(cuid())
  studentId         String
  student           Student               @relation(fields: [studentId], references: [id])
  
  // Risk and Intervention Details
  riskLevel         String
  riskCategories    RiskCategory[]
  interventions     String[]
  triggerDetails    String[]
  status            InterventionPlanStatus @default(INITIATED)
  
  // Tracking and Effectiveness
  startDate         DateTime              @default(now())
  lastReviewDate    DateTime?
  completionDate    DateTime?
  
  // Performance Metrics
  initialRiskScore  Float?
  currentRiskScore  Float?
  improvementRate   Float?
  
  // Stakeholder Involvement
  primaryAdvisorId  String?
  primaryAdvisor    Teacher?              @relation(fields: [primaryAdvisorId], references: [id])
  
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

// Risk Prediction Model
model RiskPrediction {
  id                          String              @id @default(cuid())
  studentId                   String
  student                     Student             @relation(fields: [studentId], references: [id])
  
  // Risk Prediction Details
  riskCategory                RiskCategory
  predictionScore             Float
  confidenceLevel             PredictionConfidence
  predictedOutcome            String
  
  // Contributing Factors and Recommendations
  contributingFactors         String[]
  recommendedPreventiveActions String[]
  
  // Tracking and Analysis
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Risk Trend Analysis Model
