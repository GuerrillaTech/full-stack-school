}

model LearningIntervention {
  id                      String               @id @default(cuid())
  studentId               String
  student                 Student              @relation(fields: [studentId], references: [id])
  interventionType        InterventionType
  riskLevel               RiskLevel
  interventionPlan        Json
  progressTracking        Json?
