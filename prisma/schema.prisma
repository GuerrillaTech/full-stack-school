// Collaboration Model
model Collaboration {
  id                          String              @id @default(cuid())
  
  // Collaboration Details
  name                        String
  description                 String?
  type                        CollaborationType
  status                      CollaborationStatus @default(PROSPECTIVE)
  
  // Partner Associations
  partners                    Partner[]
  
  // Project and Outcome Tracking
  projects                    CollaborationProject[]
  outcomes                    CollaborationOutcome[]
  
  // Performance Metrics
  startDate                   DateTime
  expectedEndDate             DateTime?
  actualEndDate               DateTime?
  
  // AI and Analytics Metadata
  aiGeneratedInsights         Json?
  performanceScore            Float               @default(0)
  
  // Audit and Tracking
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Collaboration Project Model
model CollaborationProject {
  id                          String              @id @default(cuid())
  
  // Project Details
  name                        String
  description                 String?
  
  // Collaboration Association
  collaborationId             String
  collaboration               Collaboration       @relation(fields: [collaborationId], references: [id])
  
  // Project Tracking
  startDate                   DateTime
  expectedEndDate             DateTime?
  actualEndDate               DateTime?
  
  // Outcome and Impact
  researchOutputs             ResearchOutput[]
  publications                Publication[]
  
  // Performance Metrics
  innovationScore             Float               @default(0)
  knowledgeTransferScore      Float               @default(0)
  
  // Metadata
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Research Output Model
model ResearchOutput {
  id                          String              @id @default(cuid())
  
  // Output Details
  title                       String
  description                 String?
  type                        String
  
  // Project and Collaboration Association
  projectId                   String
  project                     CollaborationProject @relation(fields: [projectId], references: [id])
  
  // Impact Metrics
  citations                   Int                 @default(0)
  impactFactor                Float               @default(0)
  
  // Metadata
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Publication Model
model Publication {
  id                          String              @id @default(cuid())
  
  // Publication Details
  title                       String
  authors                     String[]
  journalName                 String
  publicationDate             DateTime
  
  // Project and Collaboration Association
  projectId                   String
  project                     CollaborationProject @relation(fields: [projectId], references: [id])
  
  // Impact Metrics
  citations                   Int                 @default(0)
  impactFactor                Float               @default(0)
  
  // Metadata
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Collaboration Outcome Model
model CollaborationOutcome {
  id                          String              @id @default(cuid())
  
  // Outcome Details
  name                        String
  description                 String?
  type                        String
  
  // Collaboration Association
  collaborationId             String
  collaboration               Collaboration       @relation(fields: [collaborationId], references: [id])
  
  // Impact and Performance
  quantitativeImpact          Float
  qualitativeImpact           String?
  
  // Metadata
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Eligibility Criteria Model
model EligibilityCriteria {
  id                  String                     @id @default(cuid())
  type                EligibilityCriteriaType
  description         String
  minimumThreshold    Float
  maximumThreshold    Float?
  scholarshipId       String
  scholarship         Scholarship                @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  scholarshipProgramId String?
  scholarshipProgram  ScholarshipProgram?        @relation(fields: [scholarshipProgramId], references: [id])
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
}

// User Consent Profile Model
model UserConsentProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id])
  consentType         String
  consentStatus       Boolean   @default(false)
  consentDate         DateTime  @default(now())
  expirationDate      DateTime?
  processingPurpose   String
  lastUpdated         DateTime  @updatedAt
  notificationPreferences NotificationPreference[]
}

model NotificationPreference {
  id                  String    @id @default(cuid())
  userConsentProfileId String
  userConsentProfile  UserConsentProfile @relation(fields: [userConsentProfileId], references: [id])
  category            String
  preferenceType      String
  isEnabled           Boolean   @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Notification {
  id                  String    @id @default(cuid())
  recipientId         String
  recipient           User      @relation(fields: [recipientId], references: [id])
  category            String
  processingPurpose   String
  content             String
  isRead              Boolean   @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Consent Status Enum
enum ConsentStatus {
  PENDING
  GRANTED
  REVOKED
  EXPIRED
}

// Consent Purpose Enum
enum ConsentPurpose {
  COMMUNICATION
  PERSONALIZATION
  ANALYTICS
  MARKETING
  RESEARCH
  PERFORMANCE_TRACKING
}

// Applicable Regulation Enum
enum ApplicableRegulation {
  GDPR
  CCPA
  HIPAA
  FERPA
  COPPA
}

// Add this after existing enums
enum UserRole {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

// Add this model to the end of the file
model UserAuthentication {
  id             String   @id @default(cuid())
  username       String   @unique
  email          String   @unique
  passwordHash   String
  role           UserRole
  lastLogin      DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
