// Assessment Enums
enum AssessmentType {
  DIAGNOSTIC
  FORMATIVE
  SUMMATIVE
  PERFORMANCE_BASED
  ADAPTIVE
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LearningDomain {
  COGNITIVE
  AFFECTIVE
  PSYCHOMOTOR
  METACOGNITIVE
}

// Assessment Item Model
model AssessmentItem {
  id                          String              @id @default(cuid())
  assessmentId                String
  assessment                  Assessment          @relation(fields: [assessmentId], references: [id])
  
  // Question Details
  questionText                String
  type                        AssessmentType
  difficultyLevel             DifficultyLevel
  learningDomain              LearningDomain
  
  // Metadata
  subject                     String
  topic                       String
  learningObjective           String
  
  // Scoring
  maxScore                    Float
  scoringRubric               Json
  
  // AI and Adaptive Parameters
  aiGeneratedDistractors      String[]
  adaptiveParameters          Json?
  
  // Multimedia Support
  multimedia                  Json?
  
  // Student Responses and Performance
  studentResponses            StudentAssessmentResponse[]
  
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Assessment Model
model Assessment {
  id                          String              @id @default(cuid())
  
  // Basic Details
  title                       String
  description                 String?
  
  // Configuration
  type                        AssessmentType
  subject                     String
  learningObjectives          String[]
  
  // Temporal and Access Control
  startTime                   DateTime?
  endTime                     DateTime?
  duration                    Int?
  
  // Adaptive and Personalization
  adaptiveMode                Boolean             @default(false)
  personalizationLevel        Float               @default(0.5)
  
  // Assessment Items
  assessmentItems             AssessmentItem[]
  
  // Scoring and Evaluation
  scoringMethod               String
  passingThreshold            Float
  
  // Metadata
  createdBy                   String
  tags                        String[]
  
  // Student Results
  studentResults              StudentAssessmentResult[]
  
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Student Assessment Response Model
model StudentAssessmentResponse {
  id                          String              @id @default(cuid())
  studentId                   String
  student                     Student             @relation(fields: [studentId], references: [id])
  
  assessmentItemId            String
  assessmentItem              AssessmentItem      @relation(fields: [assessmentItemId], references: [id])
  
  // Response Details
  responseText                String?
  selectedOption              String?
  score                       Float?
  
  // Performance Metadata
  timeTaken                   Int?
  confidenceLevel             Float?
  
  createdAt                   DateTime            @default(now())
}

// Student Assessment Result Model
model StudentAssessmentResult {
  id                          String              @id @default(cuid())
  studentId                   String
  student                     Student             @relation(fields: [studentId], references: [id])
  
  assessmentId                String
  assessment                  Assessment          @relation(fields: [assessmentId], references: [id])
  
  // Performance Metrics
  totalScore                  Float
  percentageScore             Float
  performanceLevel            String
  
  // Adaptive and Personalized Insights
  personalizedFeedback        String?
  recommendedLearningPath     Json?
  
  // Performance Analysis
  strengthAreas               String[]
  improvementAreas            String[]
  
  createdAt                   DateTime            @default(now())
}

// Update Student Model
model Student {
  id                          String       @id
  username                    String       @unique
  name                        String
  surname                     String
  email                       String?      @unique
  phone                       String?      @unique
  address                     String
  img                         String?
  bloodType                   String
  sex                         UserSex
  createdAt                   DateTime     @default(now())
  parentId                    String
  parent                      Parent       @relation(fields: [parentId], references: [id])
  classId                     Int
  class                       Class        @relation(fields: [classId], references: [id])
  gradeId                     Int
  grade                       Grade        @relation(fields: [gradeId], references: [id])
  attendances                 Attendance[]
  results                     Result[]
  birthday                    DateTime
  academicInterventionPlans   AcademicInterventionPlan[]
  scholarshipEvaluations      ScholarshipEvaluation?
  learningPathways            LearningPathway[]
  learningInterventions        LearningIntervention[]
  learningProfile             StudentLearningProfile?
  studentInteractions         StudentInteraction[]
  learningRecommendations     LearningRecommendation[]
  performancePredictions      PerformancePrediction?
  personalizedLearningProfile PersonalizedLearningProfile?
  learningGoalAnalyses        LearningGoalAnalysis[]
  performanceMetrics          PerformanceMetric[]
  studentRiskAssessments      StudentRiskAssessment[]
  learningInterventionsNew    LearningIntervention[]
  learningInterventionLogs    LearningInterventionLog[]
  supportTickets              SupportTicket[]
  earlyWarningTriggers        EarlyWarningTrigger[]
  learningProfile             LearningProfile?
  recommendationHistory       RecommendationTracking[]
  equityProfile               EquityProfile?
  interventionPlans           InterventionPlan[]
  learningInterventionLogs    LearningInterventionLog[]
  riskPredictions             RiskPrediction[]
  interventionStrategies      InterventionStrategy[]
  mlSupportModels             MLSupportModel[]
  studentGrowthProfile        StudentGrowthProfile?
  studentGrowthRecords        StudentGrowthRecord[]
  researchProjects            ResearchProject[]
  assessmentResponses         StudentAssessmentResponse[]
  assessmentResults           StudentAssessmentResult[]
  learningPaths               LearningPath[]
  studentResourceProgress     StudentResourceProgress[]
  courseEnrollments           StudentCourseEnrollment[]
  studentAssessments          StudentAssessment[]
  apprenticeships             Apprenticeship[]
  scholarships                Scholarship[]
  consentProfile              UserConsentProfile?
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       String @id
  username String @unique
}

model Teacher {
  id        String    @id
  username  String    @unique
  name      String
  surname   String
  email     String?   @unique
  phone     String?   @unique
  address   String
  img       String?
  bloodType String
  sex       UserSex
  createdAt DateTime  @default(now())
  subjects  Subject[]
  lessons   Lesson[]
  classes   Class[]
  birthday  DateTime
  managedInterventionPlans  InterventionPlan[]
  managedInterventionStrategies  InterventionStrategy[]
}

model Parent {
  id        String    @id
  username  String    @unique
  name      String
  surname   String
  email     String?   @unique
  phone     String    @unique
  address   String
  createdAt DateTime  @default(now())
  students  Student[]
}

model Grade {
  id    Int @id @default(autoincrement())
  level Int @unique

  students Student[]
  classes Class[]
}

model Class {
  id       Int    @id @default(autoincrement())
  name     String @unique
  capacity Int

  supervisorId  String?
  supervisor    Teacher?       @relation(fields: [supervisorId], references: [id])
  lessons       Lesson[]
  students      Student[]
  gradeId       Int
  grade         Grade          @relation(fields: [gradeId], references: [id])
  events        Event[]
  announcements Announcement[]
}

model Subject {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  teachers Teacher[]
  lessons  Lesson[]
}

model Lesson {
  id        Int      @id @default(autoincrement())
  name      String
  day       Day
  startTime DateTime
  endTime   DateTime

  subjectId   Int
  subject     Subject      @relation(fields: [subjectId], references: [id])
  classId     Int
  class       Class        @relation(fields: [classId], references: [id])
  teacherId   String
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  exams       Exam[]
  assignments Assignment[]
  attendances Attendance[]
}

model Exam {
  id        Int      @id @default(autoincrement())
  title     String
  startTime DateTime
  endTime   DateTime

  lessonId Int
  lesson   Lesson   @relation(fields: [lessonId], references: [id])
  results  Result[]
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  startDate DateTime
  dueDate   DateTime

  lessonId Int
  lesson   Lesson   @relation(fields: [lessonId], references: [id])
  results  Result[]
}

model Result {
  id    Int @id @default(autoincrement())
  score Int

  examId       Int?
  exam         Exam?       @relation(fields: [examId], references: [id])
  assignmentId Int?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student     @relation(fields: [studentId], references: [id])
}

model Attendance {
  id      Int      @id @default(autoincrement())
  date    DateTime
  present Boolean

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  lessonId  Int
  lesson    Lesson  @relation(fields: [lessonId], references: [id])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  date        DateTime

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])
}

model Curriculum {
  id          String    @id @default(cuid())
  name        String
  description String
  gradeLevel  Int
  subjects    Subject[] @relation("CurriculumSubjects")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AcademicInterventionPlan {
  id                String   @id @default(cuid())
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id])
  interventionType  String
  description       String
  startDate         DateTime @default(now())
  endDate           DateTime?
  status            String   @default("ACTIVE")
  recommendedResources Json?
}

model ScholarshipEvaluation {
  id                String   @id @default(cuid())
  studentId         String   @unique
  student           Student  @relation(fields: [studentId], references: [id])
  evaluationDate    DateTime @default(now())
  averageScore      Float
  scholarshipLevel  String
  fundingPercentage Int
  additionalSupport Json?
}

model LearningPathway {
  id                String   @id @default(cuid())
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id])
  recommendedCourses Json
  intensityLevel    String
  lastUpdated       DateTime @default(now())
}

model LearningIntervention {
  id                String    @id @default(cuid())
  studentId         String
  student           Student   @relation(fields: [studentId], references: [id])
  subject           String
  interventionType  String
  description       String
  startDate         DateTime  @default(now())
  endDate           DateTime?
  status            String    @default("ACTIVE")
  recommendedResources Json?
}

enum UserSex {
  MALE
  FEMALE
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

enum AdmiraltyRank {
  FLEET_ADMIRAL
  VICE_ADMIRAL
  REAR_ADMIRAL
  ADMIRAL
  COMMODORE
}

enum DivisionType {
  COMMAND
  ACADEMY
  SALLIRREUG_TECH
  RESEARCH_ETHICS
}

model AdmiraltyMember {
  id            String        @id @default(cuid())
  name          String
  surname       String
  email         String        @unique
  rank          AdmiraltyRank
  division      DivisionType
  specialization String
  startDate     DateTime      @default(now())
  responsibilities String[]
  strategicInitiatives StrategicInitiative[]
}

model StrategicInitiative {
  id            String        @id @default(cuid())
  title         String
  description   String
  status        String        @default("PROPOSED")
  startDate     DateTime      @default(now())
  endDate       DateTime?
  budget        Float         @default(0)
  leaderId      String
  leader        AdmiraltyMember @relation(fields: [leaderId], references: [id])
  divisions     DivisionType[]
}

model EthicalStandard {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  description   String
  implementationDate DateTime  @default(now())
  complianceLevel Float       @default(0)
}

model CommunityOutreachProgram {
  id            String        @id @default(cuid())
  name          String
  description   String
  targetCommunity String
  startDate     DateTime      @default(now())
  endDate       DateTime?
  participantCount Int        @default(0)
  fundingAmount Float        @default(0)
}

enum AssessmentType {
  DIAGNOSTIC
  FORMATIVE
  SUMMATIVE
  PERFORMANCE_BASED
  ADAPTIVE
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Assessment {
  id                  String           @id @default(cuid())
  title               String
  subject             String
  type                AssessmentType
  gradeLevel          Int
  difficultyLevel     DifficultyLevel
  learningObjectives  String[]
  maxScore            Int
  duration            Int
  status              String           @default("DRAFT")
  createdAt           DateTime         @default(now())
  questions           Question[]
  exams               Exam[]
}

model Question {
  id                String           @id @default(cuid())
  text              String
  subjectId         Int
  subject           Subject          @relation(fields: [subjectId], references: [id])
  difficultyLevel   DifficultyLevel
  type              String
  points            Int
  correctAnswer     String
  possibleAnswers   String[]
  assessmentId      String
  assessment        Assessment       @relation(fields: [assessmentId], references: [id])
}

enum LearningStyle {
  VISUAL
  AUDITORY
  KINESTHETIC
  READING_WRITING
  MULTIMODAL
}

enum CognitiveLoadLevel {
  LOW
  MODERATE
  HIGH
  OVERWHELMING
}

model StudentLearningProfile {
  id                String           @id @default(cuid())
  studentId         String           @unique
  student           Student          @relation(fields: [studentId], references: [id])
  primaryLearningStyle LearningStyle
  cognitiveLoadLevel CognitiveLoadLevel
  learningStyleStrengths String[]
  learningStyleWeaknesses String[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model StudentInteraction {
  id                String           @id @default(cuid())
  studentId         String
  student           Student          @relation(fields: [studentId], references: [id])
  interactionType   String
  resourceType      String
  duration          Int
  engagement        Float
  timestamp         DateTime         @default(now())
}

model LearningRecommendation {
  id                String           @id @default(cuid())
  studentId         String
  student           Student          @relation(fields: [studentId], references: [id])
  recommendationType String
  description       String
  resources         Json
  startDate         DateTime         @default(now())
  endDate           DateTime?
  status            String           @default("ACTIVE")
}

model PerformancePrediction {
  id                String           @id @default(cuid())
  studentId         String           @unique
  student           Student          @relation(fields: [studentId], references: [id])
  predictedScore    Float
  confidenceInterval Json
  predictionDate    DateTime         @default(now())
  performanceGrowthPlan Json
}

enum LearningGoalType {
  ACADEMIC_IMPROVEMENT
  SKILL_DEVELOPMENT
  CAREER_PREPARATION
  PERSONAL_GROWTH
}

enum LearningPathComplexity {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model PersonalizedLearningProfile {
  id                      String               @id @default(cuid())
  studentId               String               @unique
  student                 Student              @relation(fields: [studentId], references: [id])
  primaryLearningGoal     LearningGoalType
  learningPathComplexity  LearningPathComplexity
  recommendedPrimaryPath  String
  strategicObjectives     String[]
  supportMechanisms       String[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
}

model LearningPathway {
  id                      String               @id @default(cuid())
  studentId               String
  student                 Student              @relation(fields: [studentId], references: [id])
  pathType                LearningGoalType
  focusAreas              String[]
  milestones              Json
  interventionStrategies  String[]
  progressTracking        Json?
  status                  String               @default("ACTIVE")
  startDate               DateTime             @default(now())
  expectedCompletionDate  DateTime?
  actualCompletionDate    DateTime?
}

model LearningGoalAnalysis {
  id                      String               @id @default(cuid())
  studentId               String
  student                 Student              @relation(fields: [studentId], references: [id])
  goalType                LearningGoalType
  goalInterpretation      String
  keyLearningOpportunities Json
  potentialChallenges     Json
  successProbability      Float
  analysisDate            DateTime             @default(now())
}

model PerformanceMetric {
  id                      String               @id @default(cuid())
  studentId               String
  student                 Student              @relation(fields: [studentId], references: [id])
  academicPerformance     Float
  skillDevelopment        Float
  careerPreparation       Float
  personalGrowth          Float
  overallProgressScore    Float
  metricDate              DateTime             @default(now())
}

enum AIEthicalPrincipal {
  FAIRNESS
  TRANSPARENCY
  ACCOUNTABILITY
  PRIVACY
  HUMAN_AGENCY
  NON_MALEFICENCE
}

enum BiasCategory {
  DEMOGRAPHIC
  CULTURAL
  LINGUISTIC
  SOCIOECONOMIC
  EDUCATIONAL
}

model AISystem {
  id                      String               @id @default(cuid())
  name                    String
  description             String
  trainingData            Json
  intentionType           String
  registrationDate        DateTime             @default(now())
  ethicalScreeningStatus  String?
  ethicalScreeningRemarks String?
  ethicalAuditTrails      EthicalAuditTrail[]
  biasDetectionLogs       BiasDetectionLog[]
  ethicalInterventions    EthicalIntervention[]
}

model EthicalAuditTrail {
  id                      String               @id @default(cuid())
  aiSystemId              String
  aiSystem                AISystem             @relation(fields: [aiSystemId], references: [id])
  overallEthicalScore     Float
  principalEvaluations    Json
  biasAnalysis            Json
  recommendedInterventions Json
  createdAt               DateTime             @default(now())
}

model BiasDetectionLog {
  id                      String               @id @default(cuid())
  aiSystemId              String
  aiSystem                AISystem             @relation(fields: [aiSystemId], references: [id])
  biasCategory            BiasCategory
  detectionResult         String
  biasSeverityScore       Float
  detectionDate           DateTime             @default(now())
}

model EthicalIntervention {
  id                      String               @id @default(cuid())
  aiSystemId              String
  aiSystem                AISystem             @relation(fields: [aiSystemId], references: [id])
  interventionType        String
  description             String
  recommendedActions      Json
  status                  String               @default("PENDING")
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
}

enum InterventionType {
  ACADEMIC_SUPPORT
  EMOTIONAL_SUPPORT
  SKILL_DEVELOPMENT
  CAREER_GUIDANCE
  MENTAL_HEALTH
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

model StudentRiskAssessment {
  id                          String               @id @default(cuid())
  studentId                   String
  student                     Student              @relation(fields: [studentId], references: [id])
  academicRiskLevel           RiskLevel
  emotionalRiskLevel          RiskLevel
  skillDevelopmentRiskLevel   RiskLevel
  careerPreparationRiskLevel  RiskLevel
  overallRiskLevel            RiskLevel
