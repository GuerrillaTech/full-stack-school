// Curriculum Management Enums
enum CurriculumType {
  ACADEMIC
  VOCATIONAL
  PROFESSIONAL_DEVELOPMENT
  STEM
  ARTS
  HUMANITIES
  INTERDISCIPLINARY
}

enum CourseDeliveryMode {
  IN_PERSON
  ONLINE
  HYBRID
  SELF_PACED
  COHORT_BASED
}

enum LearningOutcomeCategory {
  KNOWLEDGE
  SKILLS
  COMPETENCIES
  ATTITUDES
  PROFESSIONAL_BEHAVIORS
}

enum CurriculumStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  ACTIVE
  ARCHIVED
}

// Curriculum Model
model Curriculum {
  id                          String              @id @default(cuid())
  
  // Curriculum Identification
  title                       String
  code                        String              @unique
  type                        CurriculumType
  description                 String?
  
  // Organizational Context
  department                  String
  academicLevel               String
  
  // Metadata and Classification
  keywords                    String[]
  tags                        String[]
  
  // Curriculum Lifecycle
  status                      CurriculumStatus    @default(DRAFT)
  versionNumber               String              @default("1.0")
  
  // Temporal Tracking
  developmentStartDate        DateTime
  approvalDate                DateTime?
  implementationDate          DateTime?
  
  // Curriculum Composition
  courses                     Course[]
  learningOutcomes            LearningOutcome[]
  
  // Approval and Governance
  developedBy                 String
  approvedBy                  String?
  
  // Performance and Impact
  studentEnrollmentCount      Int                 @default(0)
  successRate                 Float?
  
  // AI and Analytics
  aiGeneratedInsights         Json?
  
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Course Model
model Course {
  id                          String              @id @default(cuid())
  
  // Course Identification
  title                       String
  code                        String              @unique
  description                 String?
  
  // Curriculum Association
  curriculumId                String
  curriculum                  Curriculum          @relation(fields: [curriculumId], references: [id])
  
  // Course Metadata
  creditHours                 Float
  deliveryMode                CourseDeliveryMode
  
  // Temporal Details
  startDate                   DateTime
  endDate                     DateTime
  
  // Instructional Design
  learningObjectives          String[]
  prerequisites               String[]
  
  // Resource Allocation
  instructors                 String[]
  recommendedResources        String[]
  
  // Performance Tracking
  enrolledStudents            StudentCourseEnrollment[]
  assessments                 CourseAssessment[]
  
  // AI-Enhanced Features
  difficultyLevel             String?
  adaptiveLearningScore       Float?
  
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Learning Outcome Model
model LearningOutcome {
  id                          String              @id @default(cuid())
  
  // Curriculum Association
  curriculumId                String
  curriculum                  Curriculum          @relation(fields: [curriculumId], references: [id])
  
  // Outcome Identification
  title                       String
  description                 String?
  
  // Categorization
  category                    LearningOutcomeCategory
  
  // Measurable Criteria
  performanceIndicators       String[]
  assessmentMethods           String[]
  
  // Alignment and Mapping
  alignedCompetencies         String[]
  relatedCourses              String[]
  
  // Performance Tracking
  achievementRate             Float?
  
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Student Course Enrollment Model
model StudentCourseEnrollment {
  id                          String              @id @default(cuid())
  
  // Student and Course Context
  studentId                   String
  student                     Student             @relation(fields: [studentId], references: [id])
  
  courseId                    String
  course                      Course              @relation(fields: [courseId], references: [id])
  
  // Enrollment Details
  enrollmentDate              DateTime            @default(now())
  status                      String              @default("ACTIVE")
  
  // Performance Tracking
  progressPercentage          Float               @default(0)
  finalGrade                  String?
  
  // Engagement Metrics
  attendanceRate              Float?
  participationScore          Float?
  
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Course Assessment Model
model CourseAssessment {
  id                          String              @id @default(cuid())
  
  // Course Context
  courseId                    String
  course                      Course              @relation(fields: [courseId], references: [id])
  
  // Assessment Metadata
  title                       String
  type                        String
  description                 String?
  
  // Temporal Details
  scheduledDate               DateTime
  duration                    Int                 @default(60)
  
  // Assessment Configuration
  maximumScore                Float
  passingThreshold            Float
  
  // Student Performance
  studentAssessments          StudentAssessment[]
  
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

// Student Assessment Model
model StudentAssessment {
  id                          String              @id @default(cuid())
  
  // Assessment and Student Context
  assessmentId                String
  assessment                  CourseAssessment    @relation(fields: [assessmentId], references: [id])
  
  studentId                   String
  student                     Student             @relation(fields: [studentId], references: [id])
  
  // Performance Metrics
  score                       Float
  percentageScore             Float
  
  // Qualitative Feedback
  feedback                    String?
  
  // AI-Enhanced Insights
  performanceCategory         String?
  improvementRecommendations  String[]
  
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

