// Apprenticeship Model
model Apprenticeship {
  id                          String              @id @default(cuid())
  
  // Student and Program Association
  studentId                   String
  student                     Student             @relation(fields: [studentId], references: [id])
  
  programId                   String
  program                     ApprenticeshipProgram @relation(fields: [programId], references: [id])
  
