  startDate               DateTime             @default(now())
  expectedCompletionDate  DateTime?
  actualCompletionDate    DateTime?
}

model LearningInterventionLog {
  id                      String               @id @default(cuid())
  studentId               String
  student                 Student              @relation(fields: [studentId], references: [id])
  interventionType        InterventionType
  interventionPlanId      String
  interventionPlan        Json
  loggedAt                DateTime             @default(now())
}

model SupportTicket {
  id                      String               @id @default(cuid())
  interventionPlanId      String?
  studentId               String?
  student                 Student?             @relation(fields: [studentId], references: [id])
  priority                String
  status                  String
  description             String
  assignedTo              String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
}

model EarlyWarningTrigger {
  id                      String               @id @default(cuid())
  studentId               String
  student                 Student              @relation(fields: [studentId], references: [id])
  riskType                String
  currentRiskLevel        RiskLevel
  triggerDescription      String
  detectedAt              DateTime             @default(now())
}

enum CollaborationMode {
  PEER_LEARNING
  GROUP_PROJECT
  MENTORSHIP
  CROSS_DISCIPLINARY
  GLOBAL_CHALLENGE
}

enum KnowledgeType {
  ACADEMIC
  SKILL_BASED
  RESEARCH
  INNOVATION
  PROFESSIONAL_DEVELOPMENT
}

model User {
  id       String @id
  username String @unique
  userKnowledgeProfile    UserKnowledgeProfile?
  collaborativeLearningGroups CollaborativeLearningGroup[]
  knowledgeContributions  KnowledgeContribution[]
  knowledgeRecommendations KnowledgeRecommendation[]
  userLearningProfile     UserLearningProfile?
  personalizedLearningPathways PersonalizedLearningPathway[]
  skillDevelopmentTracking SkillDevelopmentTracking[]
  learningResourceRecommendations LearningResourceRecommendation[]
  careerDevelopmentPathways CareerDevelopmentPathway[]
  userSkillProfile        UserSkillProfile?
  notifications Notification[]
  researcher              Researcher?
  managedDivisions        Division[]
  notificationPreferences  NotificationPreference?
  consentProfile           UserConsentProfile?
}

model UserKnowledgeProfile {
  id                      String               @id @default(cuid())
  userId                  String               @unique
  user                    User                 @relation(fields: [userId], references: [id])
  totalContributions      Int                  @default(0)
  cumulativeQualityScore  Float                @default(0)
  contributionIds         String[]
