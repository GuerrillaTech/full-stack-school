  actualCompletionDate    DateTime?
}

model SkillDevelopmentTracking {
  id                      String               @id @default(cuid())
  userId                  String
  user                    User                 @relation(fields: [userId], references: [id])
  skillName               String
  currentSkillLevel       SkillLevel
  learningActivities      Json
  skillProgressAnalysis   Json
  recommendedNextSteps    Json
  trackingDate            DateTime             @default(now())
}

model LearningResourceRecommendation {
  id                      String               @id @default(cuid())
  userId                  String
  user                    User                 @relation(fields: [userId], references: [id])
  learningDomain          String
  currentSkillLevel       SkillLevel
  recommendedResources    Json
  recommendationDate      DateTime             @default(now())
}

model CareerDevelopmentPathway {
  id                      String               @id @default(cuid())
  userId                  String
  user                    User                 @relation(fields: [userId], references: [id])
  careerGoal              String
  pathwayDetails          Json
  skillDevelopmentRoadmap Json
  status                  String               @default("IN_PROGRESS")
  startDate               DateTime             @default(now())
  expectedCompletionDate  DateTime?
  actualCompletionDate    DateTime?
}

model UserSkillProfile {
  id                      String               @id @default(cuid())
  userId                  String               @unique
  user                    User                 @relation(fields: [userId], references: [id])
